{
  "name": "Expense",
  "type": "object",
  "properties": {
    "description": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "project_name": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "travel",
        "accommodation",
        "materials",
        "software",
        "subcontractor",
        "office",
        "training",
        "other"
      ]
    },
    "amount": {
      "type": "number"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "submitted_by": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "paid"
      ],
      "default": "pending"
    },
    "receipt_url": {
      "type": "string"
    },
    "approved_by": {
      "type": "string"
    }
  },
  "required": [
    "description",
    "amount",
    "category"
  ]
}