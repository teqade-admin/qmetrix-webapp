{
  "name": "Employee",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "phone": {
      "type": "string"
    },
    "department": {
      "type": "string",
      "enum": [
        "cost_management",
        "quantity_surveying",
        "project_management",
        "commercial",
        "finance",
        "administration",
        "executive"
      ]
    },
    "job_title": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "director",
        "associate_director",
        "senior_consultant",
        "consultant",
        "junior_consultant",
        "analyst",
        "administrator"
      ]
    },
    "app_role": {
      "type": "string",
      "enum": [
        "super_admin",
        "hr_admin",
        "hr_user",
        "ops_admin",
        "ops_user",
        "finance_admin",
        "finance_user"
      ],
      "default": "ops_user"
    },
    "hourly_rate": {
      "type": "number",
      "description": "Charge-out rate \u00a3/hr"
    },
    "cost_rate": {
      "type": "number",
      "description": "Internal cost rate \u00a3/hr"
    },
    "salary": {
      "type": "number",
      "description": "Annual salary"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "on_leave",
        "terminated"
      ],
      "default": "active"
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "onboarding_status": {
      "type": "string",
      "enum": [
        "not_started",
        "in_progress",
        "completed"
      ],
      "default": "not_started"
    },
    "onboarding_checklist": {
      "type": "object",
      "description": "Per-stage onboarding completion flags"
    },
    "kpi_score": {
      "type": "number",
      "description": "Latest KPI score 0-100"
    },
    "kpi_target": {
      "type": "number",
      "description": "Target KPI score 0-100"
    },
    "goals": {
      "type": "string",
      "description": "Free-text goals / objectives"
    },
    "performance_rating": {
      "type": "string",
      "enum": [
        "exceptional",
        "exceeds_expectations",
        "meets_expectations",
        "needs_improvement",
        "unsatisfactory"
      ]
    },
    "manager_name": {
      "type": "string",
      "description": "Denormalized manager display name; kept in sync with manager_id"
    },
    "manager_id": {
      "type": "string",
      "description": "Employee id of this person's line manager (self-referencing)"
    },
    "contract_url": {
      "type": "string",
      "description": "Deprecated single contract path (superseded by contracts[])"
    },
    "contracts": {
      "type": "array",
      "description": "Employment contracts [{name, path, status, uploaded_at}] — newest is active",
      "items": { "type": "object" }
    },
    "documents": {
      "type": "array",
      "description": "Collected onboarding documents [{name, url}]",
      "items": { "type": "object" }
    },
    "allocated_projects": {
      "type": "array",
      "description": "Names of projects this employee is allocated to",
      "items": { "type": "string" }
    },
    "avatar_url": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "full_name",
    "email",
    "department",
    "role"
  ]
}